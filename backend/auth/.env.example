# ============================================================
# SPC Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Variables marked REQUIRED will cause the server to exit
# on startup if missing (unless NODE_ENV=test).
# ============================================================

# ---- Server ------------------------------------------------
PORT=4000
NODE_ENV=development        # development | production | test

# ---- CORS (REQUIRED) ---------------------------------------
# Origins allowed to make credentialed requests.
FRONTEND_ORIGIN=http://localhost:3000
LOCAL_ORIGIN=http://localhost:3000

# ---- Database (REQUIRED) -----------------------------------
PGHOST=localhost
PGPORT=5432
PGUSER=your_db_user
PGPASSWORD=your_db_password
PGDATABASE=spc_dev
# PGTESTDATABASE=spc_test   # used when NODE_ENV=test

# ---- Sessions ----------------------------------------------
SESSION_COOKIE_NAME=sid     # name of the HttpOnly session cookie
SESSION_TTL_HOURS=24        # sliding session lifetime in hours

# ---- Email (optional — set EMAIL_ENABLED=true to activate) -
EMAIL_ENABLED=false
RESEND_API_KEY=             # required when EMAIL_ENABLED=true
APP_BASE_URL=               # e.g. https://app.yourdomain.com — required when EMAIL_ENABLED=true
EMAIL_FROM_BOOKINGS=        # e.g. bookings@yourdomain.com
EMAIL_TO_OFFICE=            # internal office notification address

# ---- Email path overrides (optional) -----------------------
EMAIL_VERIFY_PATH=/verify-email
PASSWORD_RESET_PATH=/reset-password
NEW_ACC_SETUP_PATH=/new-account-setup

# ---- Security logging (optional) ---------------------------
SUSPICIOUS_IPS_PATH=log/suspiciousIps.json
